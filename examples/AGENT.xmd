# Agent Demo

@goal
Prepare a tiny build: make an output folder, write a note, and read it back.

@memory
project: "agent-demo"

@tasks
- [ ] create the output folder -> make_folder
- [ ] write a note file -> write_note
- [ ] read the note back -> verify

@workflow make_folder
- @print
  text: "creating output folder for {{ memory.project }}"

@workflow write_note
- @write
  path: out/note.txt
  content: |
    note for {{ memory.project }}
    generated by the xmd agent engine

@workflow verify
- @read
  path: out/note.txt

@on_done
set: memory.runtime.stage = "agent-checked"
